# Alpaca Paper Trading only — never use live API keys or live base URL.
# Copy to .env.local and fill in your paper credentials from:
# https://app.alpaca.markets/paper/dashboard/overview

ALPACA_API_KEY=PK36MBZG4F2UOQA2EUC5JAL5BQ
ALPACA_SECRET_KEY=5dGY9cPCMg7Y1oGfUTQh49XpWZHhPNwhW96uFNoUSoon

# REQUIRED: must be the paper trading endpoint. Live api.alpaca.markets is blocked.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Comma-separated symbols for the dashboard watchlist (Phase 2)
WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA

# Manual paper order execution is OFF by default.
# Only set to true when you intentionally want to place paper trades after manual approval.
# Never enables live/real-money trading.
# ENABLE_PAPER_ORDER_EXECUTION=true

# Safe paper order limits (used when execution is enabled)
MAX_PAPER_TRADE_NOTIONAL=500
MAX_DAILY_PAPER_TRADES=5

# News provider: mock (default) | finnhub | none
NEWS_PROVIDER=finnhub
FINNHUB_API_KEY=d9877tpr01qi7uru4pggd9877tpr01qi7uru4ph0
# AI news interpretation: heuristic (default) | ollama
AI_PROVIDER=heuristic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Keep AI Assistant trading-focused (default). Set true only if you want open general chat.
GENERAL_AI_MODE=false
# Optional: Ollama generate timeout in ms (default 75000, range 5000–180000)
# OLLAMA_TIMEOUT_MS=75000
# Per-symbol news enrichment timeout (default 20000) — keeps Control Room responsive
# OLLAMA_NEWS_TIMEOUT_MS=20000
