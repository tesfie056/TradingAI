# Alpaca Paper Trading only — never use live API keys or live base URL.
# Copy to .env.local and fill in your paper credentials from:
# https://app.alpaca.markets/paper/dashboard/overview

ALPACA_API_KEY=your_paper_api_key_here
ALPACA_SECRET_KEY=your_paper_secret_key_here

# REQUIRED: must be the paper trading endpoint. Live api.alpaca.markets is blocked.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Comma-separated symbols for the dashboard watchlist (Version 1 default ≈$5–$50 liquid U.S. stocks)
WATCHLIST=F,T,VZ,PFE,WBD,NOK,AAL,CMCSA,HPE,RIG,HBAN,CCL,ITUB,VALE,ERIC,HPQ

# Manual paper order execution is OFF by default.
# Only set to true when you intentionally want to place paper trades after manual approval.
# Never enables live/real-money trading.
# ENABLE_PAPER_ORDER_EXECUTION=true

# Small Account Mode — fractional/notional paper sizing for lower-dollar tests
SMALL_ACCOUNT_MODE=true
DEFAULT_ORDER_MODE=notional
DEFAULT_NOTIONAL_AMOUNT=10
MAX_NOTIONAL_PER_TRADE=25
# MIN_STOCK_PRICE=2
# MAX_STOCK_PRICE=50
# MIN_AVG_DAILY_VOLUME=1000000
# MAX_SPREAD_PERCENT=0.5
# AVOID_OTC=true

# Safe paper order limits (used when execution is enabled)
MAX_PAPER_TRADE_NOTIONAL=500
MAX_DAILY_PAPER_TRADES=5

# News provider: mock (default) | finnhub | none
NEWS_PROVIDER=finnhub
FINNHUB_API_KEY=your_finnhub_api_key_here
# AI news interpretation: heuristic (default) | ollama
AI_PROVIDER=heuristic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Keep AI Assistant trading-focused (default). Set true only if you want open general chat.
GENERAL_AI_MODE=false
# Optional: Ollama generate timeout in ms (default 75000, range 5000–180000)
# OLLAMA_TIMEOUT_MS=75000
# Per-symbol news enrichment timeout (default 20000) — keeps Control Room responsive
# OLLAMA_NEWS_TIMEOUT_MS=20000

# Phase 7 — background monitor worker + SSE live updates
# MONITOR_WORKER_AUTO_START=true
# MONITOR_INTERVAL_OPEN_MS=90000
# MONITOR_INTERVAL_CLOSED_MS=900000
# MONITOR_HEARTBEAT_MS=5000
# QUOTE_CACHE_TTL_MS=25000
# NEWS_CACHE_TTL_MS=300000
# MONITOR_MIN_SCAN_GAP_MS=60000

# Phase 8 — automatic PAPER trading (disabled by default; never enables live trading)
# AUTO_PAPER_TRADING_ENABLED=false
# DEFAULT_ORDER_MODE=notional
# DEFAULT_NOTIONAL_AMOUNT=5
# MAX_NOTIONAL_PER_TRADE=10
# MAX_DAILY_PAPER_TRADES=3
# MAX_DAILY_PAPER_LOSS=10
# MIN_CONFIDENCE_FOR_AUTO_TRADE=75
# AUTO_TRADE_COOLDOWN_MINUTES=30
# ALLOW_SELL_AUTO=false

# Phases 9–15 — strategy version + training loop
# STRATEGY_VERSION=v1.0.0

# Risk engine + universe (paper auto-trading)
# UNIVERSE_MIN_PRICE=5
# UNIVERSE_MAX_PRICE=50
# UNIVERSE_MIN_AVG_DAILY_VOLUME=1000000
# UNIVERSE_MAX_SPREAD_PERCENT=0.5
# RISK_MAX_OPEN_POSITIONS=3
# RISK_MAX_RISK_PER_TRADE_PCT=0.5
# RISK_MAX_POSITION_ALLOCATION_PCT=10
# RISK_MAX_DAILY_LOSS_PCT=2
# RISK_CONSECUTIVE_LOSS_PAUSE=3
# RISK_OPEN_ENTRY_DELAY_MINUTES=0
# RISK_EOD_ENTRY_CUTOFF_MINUTES=30
# RISK_REGULAR_HOURS_ONLY=true
# RISK_LONG_ONLY=true
# RISK_DEFAULT_STOP_LOSS_PCT=1.5
# RISK_DEFAULT_TAKE_PROFIT_PCT=3

# Phase H — conservative paper soak profile (paper only; never live)
# When PAPER_SOAK_PROFILE=true, defaults become:
#   max 1 open position, 2 trades/day, 0.25% risk/trade, 5% allocation,
#   1% daily loss, long only, RTH only, no entries first 15m / last 45m
# PAPER_SOAK_PROFILE=true
# MAX_DAILY_PAPER_TRADES=2
# RISK_MAX_OPEN_POSITIONS=1
# RISK_MAX_RISK_PER_TRADE_PCT=0.25
# RISK_MAX_POSITION_ALLOCATION_PCT=5
# RISK_MAX_DAILY_LOSS_PCT=1
# RISK_OPEN_ENTRY_DELAY_MINUTES=15
# RISK_EOD_ENTRY_CUTOFF_MINUTES=45
# ALLOW_SELL_AUTO=false
# Optional override (comma-separated). Default is ~30 liquid mid-price names.
# PAPER_SOAK_WATCHLIST=F,BAC,T,VZ,PFE,INTC,SOFI,NIO,SNAP,WBD,AAL,CCL,KEY,RF,HBAN,ET,KMI,MO,VALE,ITUB,NOK,ERIC,GRAB,RIVN,HOOD,NU,DKNG,MARA,UBER,PLTR
